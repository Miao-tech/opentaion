# api/.env — copy this file to .env and fill in values
# Production values are set as Railway environment variables instead

# ── Local development (Supabase local stack) ──────────────────────────────────
# After running `supabase start`, get these values from `supabase status`
#
# LOCAL=true              ← disables SSL requirement for localhost Postgres
# DATABASE_URL            ← use the DB URL from `supabase status` (port 54322)
# SUPABASE_JWT_PUBLIC_KEY ← get from http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
# CORS_ORIGINS            ← both localhost and 127.0.0.1 variants for Vite

LOCAL=true
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWT_PUBLIC_KEY={"kty":"EC","alg":"ES256",...}
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM Providers ─────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY alone is sufficient for backward compatibility.
# To use additional providers, add PROVIDER_{NAME}_BASE_URL + PROVIDER_{NAME}_API_KEY.
# Clients select a provider by prefixing the model name:
#   "siliconflow/Qwen/Qwen2.5-72B-Instruct" → SiliconFlow
#   "gemini/gemini-2.0-flash"               → Gemini
#   "nvidia/nemotron-3-super-120b-a12b:free" → OpenRouter (default, no prefix needed)
# DEFAULT_PROVIDER controls the fallback when no prefix matches (default: openrouter)

OPENROUTER_API_KEY=sk-or-...

# PROVIDER_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# PROVIDER_SILICONFLOW_API_KEY=sk-sf-...
# PROVIDER_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# PROVIDER_GEMINI_API_KEY=AIza...
# DEFAULT_PROVIDER=openrouter

# ── Production (Railway) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres.xxx:PASSWORD@aws-X.pooler.supabase.com:6543/postgres
# SUPABASE_JWT_PUBLIC_KEY={"kty":"EC","alg":"ES256",...}
# OPENROUTER_API_KEY=sk-or-...
# CORS_ORIGINS=https://opentaion.vercel.app
