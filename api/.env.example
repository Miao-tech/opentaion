# api/.env — copy this file to .env and fill in values
# Production values are set as Railway environment variables instead

# ── Local development (Supabase local stack) ──────────────────────────────────
# After running `supabase start`, get these values from `supabase status`
#
# LOCAL=true              ← disables SSL requirement for localhost Postgres
# DATABASE_URL            ← use the DB URL from `supabase status` (port 54322)
# SUPABASE_JWT_PUBLIC_KEY ← get from http://localhost:54321/auth/v1/.well-known/jwks.json
# OPENROUTER_API_KEY      ← your OpenRouter key (same as production)
# CORS_ORIGINS            ← http://localhost:5173 (Vite dev server)

LOCAL=true
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_JWT_PUBLIC_KEY={"kty":"EC","alg":"ES256",...}
OPENROUTER_API_KEY=sk-or-...
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Production (Railway) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres.xxx:PASSWORD@aws-X.pooler.supabase.com:6543/postgres
# SUPABASE_JWT_PUBLIC_KEY={"kty":"EC","alg":"ES256",...}
# OPENROUTER_API_KEY=sk-or-...
# CORS_ORIGINS=https://opentaion.vercel.app
